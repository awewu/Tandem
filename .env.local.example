# =============================================================================
# Tandem / 牛马搭子 - Environment Variables Template
# =============================================================================

# -----------------------------------------------------------------------------
# Brand (品牌切换)
# -----------------------------------------------------------------------------
# Default: tandem (牛马搭子). Override with profile id from lib/brand/config.ts
NEXT_PUBLIC_BRAND_PROFILE=tandem
NEXT_PUBLIC_APP_NAME=Tandem

# -----------------------------------------------------------------------------
# Legacy Hermes API (for existing components, will be migrated)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_HERMES_API_URL=http://localhost:8000
HERMES_API_KEY=

# -----------------------------------------------------------------------------
# TAF · LLM Providers
# 至少配置 1 个; 缺失的会被 router 自动跳过.
# 开发期推荐: 仅配 HERMES (本地 Ollama, 零成本).
# -----------------------------------------------------------------------------

# DeepSeek (主力推理 - 议事室 / 3+1 / 拿捏老板)
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_KEY=

# Qwen (工具调用 / RAG)
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-max
QWEN_API_KEY=

# Doubao (高频低成本 - Check-in / 通知)
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-1-5-pro-256k
DOUBAO_API_KEY=

# Kimi (长上下文 - 复盘)
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-128k
KIMI_API_KEY=

# Hermes 4 (本地 Ollama / vLLM, 开发期主力)
HERMES_BASE_URL=http://localhost:11434/v1
HERMES_MODEL=hermes3
HERMES_API_KEY=ollama

# -----------------------------------------------------------------------------
# Persistence (Prisma + PostgreSQL)
#
# 设置 DATABASE_URL 即切换到 Prisma store (生产路径, V1 GA 建议).
# 不配置 → 自动回退 in-memory store (dev / e2e).
# 生产期设置流程见 docs/PRISMA-SETUP.md
# -----------------------------------------------------------------------------
# DATABASE_URL=postgresql://tandem:tandem@localhost:5432/tandem?schema=public

# -----------------------------------------------------------------------------
# 自研身份系统 (Native Auth - V1 主路径)
# -----------------------------------------------------------------------------
# JWT / Session 签名密钥. 生产用 openssl rand -base64 48 生成
NEXTAUTH_SECRET=change-me-in-prod-use-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# MFA TOTP secret 加密 (可选, 留空则用 NEXTAUTH_SECRET 派生)
MFA_ENCRYPTION_KEY=

# 首次启动自动创建 owner (幂等; 无配置则跳过)
TANDEM_BOOTSTRAP_OWNER_EMAIL=admin@tandem.local
TANDEM_BOOTSTRAP_OWNER_PASSWORD=ChangeMeAtFirstLogin!2026
TANDEM_BOOTSTRAP_OWNER_NAME=Tandem Owner

# -----------------------------------------------------------------------------
# 第三方 SSO (可选, 仅作为 Native Auth 的补充)

# 钉钉
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=

# 企微
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=

# 飞书
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# -----------------------------------------------------------------------------
# OSS Integrations (P3)
# -----------------------------------------------------------------------------

# Rocket.Chat IM
ROCKETCHAT_BASE_URL=http://localhost:3001
ROCKETCHAT_USER_ID=
ROCKETCHAT_AUTH_TOKEN=

# Email Tier 1 (universal IMAP/SMTP)
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USER=
EMAIL_IMAP_PASSWORD=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=

# Cal.com
CALCOM_BASE_URL=http://localhost:3002
CALCOM_API_KEY=

# MinIO (对象存储)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=tandem

# Tencent Meeting (寄生 - V2 启用)
TENCENT_MEETING_APP_ID=
TENCENT_MEETING_SECRET_ID=
TENCENT_MEETING_SECRET_KEY=

# -----------------------------------------------------------------------------
# Budget / 预算守门 (CircleBot 对齐)
# -----------------------------------------------------------------------------
TANDEM_DAILY_TOKEN_BUDGET=10000000  # 10M tokens / day / tenant
TANDEM_AGENT_MAX_STEPS=8

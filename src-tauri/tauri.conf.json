{
  "productName": "Tandem",
  "version": "1.0.0",
  "identifier": "local.tandem.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3001",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Tandem · 牛马搭子",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "transparent": false,
        "decorations": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "category": "Productivity",
    "shortDescription": "OKR 驱动的企业 AI Agent OS",
    "longDescription": "Tandem 是为 OKR 而活的企业 Agent 操作系统 — 当飞书让你协作得更快, Tandem 让你协作得更对. 议事 17 分钟硬上限 + AI 给 4 选项 (D 选项必员工原创) + Memory 三级签批 + KPI/TTI 双轨永不挂奖金.",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}

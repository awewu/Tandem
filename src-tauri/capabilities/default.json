{
  "identifier": "default",
  "description": "Tandem · Desktop client capabilities (webview + system integration)",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:webview:default",
    "core:app:default",
    "shell:allow-open",
    "notification:default",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "global-shortcut:allow-is-registered",
    "autostart:allow-enable",
    "autostart:allow-disable",
    "autostart:allow-is-enabled",
    "store:default",
    "updater:default",
    "process:default"
  ]
}

# ============================================================
# Tandem · 生产环境变量 (.env.production)
# ============================================================
# 用法:
#   cp .env.production.example .env.production
#   # 把所有 CHANGE_ME 改成强随机值 (推荐: openssl rand -hex 32)
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d
#
# 严禁:
#   - 把这个文件提交到 git (已经在 .gitignore)
#   - 使用占位密码 / 弱密码 (production-guard.ts 会拒绝启动)
# ============================================================

# ───── App ─────
NODE_ENV=production
APP_PORT=3000
LOG_LEVEL=info
NEXTAUTH_URL=https://your-domain.example.com         # 必须是真实部署域名 (用于回调 / cookie domain)

# ───── PostgreSQL ─────
POSTGRES_USER=tandem
POSTGRES_PASSWORD=CHANGE_ME_postgres_strong_password_32_chars
POSTGRES_DB=tandem
# DATABASE_URL compose 会自动从上面三个拼出来; 这里仅用于本地 db:migrate / db:studio
DATABASE_URL=postgresql://tandem:CHANGE_ME_postgres_strong_password_32_chars@postgres:5432/tandem

# ───── Redis (session, rate-limit, cache) ─────
REDIS_PASSWORD=CHANGE_ME_redis_strong_password_32_chars

# ───── MinIO / S3 (Drive 文件) ─────
MINIO_ROOT_USER=tandem
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_strong_password_32_chars
S3_BUCKET_DRIVE=tandem-drive
S3_BUCKET_ATTACHMENTS=tandem-attachments

# ───── Auth secrets (生产必须强随机) ─────
# 生成: openssl rand -hex 32
NEXTAUTH_SECRET=CHANGE_ME_nextauth_secret_64_hex_chars_min
SESSION_SECRET=CHANGE_ME_session_secret_64_hex_chars_min
MFA_ENCRYPTION_KEY=CHANGE_ME_mfa_encryption_key_64_hex_chars_min

ACCESS_TOKEN_TTL_SEC=900
SESSION_TTL_SEC=604800
BCRYPT_ROUNDS=12

# ───── Demo bypass (生产必须 0) ─────
ALLOW_DEMO_AUTH=0

# ───── 首次启动自动建 Owner 账号 ─────
# 第一次容器起来时, bootstrapOwnerIfMissing() 会用这两个变量建 owner.
# 启动后建议立刻: 1) 登录改密  2) 启用 MFA  3) 设置 ALLOW_DEMO_AUTH=0
TANDEM_BOOTSTRAP_OWNER_EMAIL=admin@your-domain.example.com
TANDEM_BOOTSTRAP_OWNER_PASSWORD=CHANGE_ME_first_admin_strong_password_18_chars
TANDEM_BOOTSTRAP_OWNER_NAME=Tandem Owner

# ───── Rate limiting ─────
RATE_LIMIT_LOGIN_PER_HOUR=5
RATE_LIMIT_API_PER_MINUTE=120

# ───── LLM Providers (至少配一个, 否则 AI 功能降级) ─────
# DeepSeek (主力, 性价比高, 国内可达)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Claude (可选, 长文/推理强)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# OpenAI (可选)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ───── 监控 (可选) ─────
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

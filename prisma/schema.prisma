generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String                   @id @default(cuid())
  email            String                   @unique
  emailVerifiedAt  DateTime?
  name             String
  avatarUrl        String?
  departmentId     String?
  managerId        String?
  tenantId         String                   @default("default")
  roles            String[]                 @default([])
  ssoBindings      Json?
  disabled         Boolean                  @default(false)
  failedLoginCount Int                      @default(0)
  lockedUntil      DateTime?
  lastLoginAt      DateTime?
  lastLoginIp      String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  deletedAt        DateTime?
  checkIns         CheckIn[]
  decisionCards    DecisionCard[]
  invitesSent      Invite[]                 @relation("InviteSender")
  keyResults       KeyResult[]
  materials        Material[]
  promotionsOpened MemoryPromotionRequest[]
  mfaSecret        MfaSecret?
  objectives       Objective[]
  passwordHash     PasswordHash?
  personas         Persona?
  sessions         Session[]
  ttis             TTI[]
  department       Department?              @relation(fields: [departmentId], references: [id])
  manager          User?                    @relation("ReportTo", fields: [managerId], references: [id])
  reports          User[]                   @relation("ReportTo")

  // A2.2 SaaS: workspace membership
  workspaceId      String?
  workspace        Workspace?               @relation(fields: [workspaceId], references: [id])

  @@index([tenantId])
  @@index([email])
  @@index([workspaceId])
}

model PasswordHash {
  userId        String   @id
  /// argon2id / bcrypt hash
  hash          String
  algorithm     String   @default("argon2id")
  /// 强制下次登录改密 (admin 重置后)
  mustChange    Boolean  @default(false)
  changedAt     DateTime @default(now())
  /// 密码历史 hash (防止复用最近 N 次)
  historyHashes String[] @default([])
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id                String    @id @default(cuid())
  userId            String
  /// 设备指纹 (UA + IP hash)
  deviceFingerprint String?
  userAgent         String?
  ip                String?
  /// 会话刷新令牌哈希 (refresh token, 永不明文存)
  refreshTokenHash  String    @unique
  /// 是否提升到 MFA 已验证状态
  mfaVerified       Boolean   @default(false)
  expiresAt         DateTime
  revokedAt         DateTime?
  revokeReason      String?
  createdAt         DateTime  @default(now())
  lastSeenAt        DateTime  @default(now())
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model MfaSecret {
  userId             String    @id
  /// TOTP secret (encrypted at rest, 仅 server 可解)
  encryptedSecret    String
  /// 10 个一次性恢复码 (hash)
  recoveryCodeHashes String[]  @default([])
  enrolledAt         DateTime  @default(now())
  lastUsedAt         DateTime?
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Invite {
  id                 String    @id @default(cuid())
  /// 邀请码 hash (明文不入库)
  codeHash           String    @unique
  /// 锁定到特定邮箱 (可选; 不锁则任何邮箱可领)
  email              String?
  /// 预设角色 / 部门
  presetRoles        String[]  @default([])
  presetDepartmentId String?
  tenantId           String    @default("default")
  /// 谁发的
  invitedById        String
  /// 备注 (本次邀请用途)
  note               String?
  /// 单次 / 多次使用
  maxUses            Int       @default(1)
  usedCount          Int       @default(0)
  expiresAt          DateTime
  redeemedAt         DateTime?
  createdAt          DateTime  @default(now())
  invitedBy          User      @relation("InviteSender", fields: [invitedById], references: [id])

  @@index([email])
  @@index([expiresAt])
  @@index([invitedById])
}

model AuthEvent {
  id        String   @id @default(cuid())
  userId    String?
  email     String?
  /// 事件类型: register | login | login_failed | logout | mfa_verified | mfa_failed | password_changed | invite_redeemed | session_revoked
  eventType String
  ip        String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([email])
  @@index([eventType])
  @@index([createdAt])
}

model Department {
  id        String       @id @default(cuid())
  name      String
  parentId  String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  parent    Department?  @relation("DeptParent", fields: [parentId], references: [id])
  children  Department[] @relation("DeptParent")
  users     User[]
}

model DecisionCard {
  id               String       @id @default(cuid())
  schemaVersion    String       @default("tandem.v1")
  title            String
  decisionClass    String
  convergenceState String
  elapsedSeconds   Int          @default(0)
  hardDeadlineAt   DateTime?
  relatedKr        String[]     @default([])
  relatedTti       String[]     @default([])
  origins          Json?
  materialRefs     String[]     @default([])
  options          Json
  selected         String?
  selectedById     String?
  selectedAt       DateTime?
  expectedKrImpact Json?
  retrospective    Json?
  vetoWindowEnds   DateTime?
  watermark        Json
  createdById      String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  deletedAt        DateTime?
  noKrReason       String?
  primaryKrId      String?
  actionItems      ActionItem[]
  createdBy        User         @relation(fields: [createdById], references: [id])
  initiatives      Initiative[] @relation("DecisionInitiatives")

  @@index([convergenceState])
  @@index([createdById])
  @@index([createdAt])
}

model ActionItem {
  id             String       @id @default(cuid())
  decisionCardId String
  ownerId        String
  task           String
  due            DateTime
  status         String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  decisionCard   DecisionCard @relation(fields: [decisionCardId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([status])
}

model Persona {
  id               String   @id @default(cuid())
  userId           String   @unique
  schemaVersion    String   @default("tandem.v1")
  stage            String
  stageEnteredAt   DateTime
  delegationLevel  String
  decisionHistory  Json
  styleProfile     Json
  growthAreas      Json
  bossCaptureScore Float    @default(0)
  dataOwnership    Json
  learningActive   Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Origin {
  id               String   @id @default(cuid())
  type             String
  sourceUrl        String?
  participants     String[] @default([])
  encryptedBlobRef String?
  retentionDays    Int      @default(90)
  createdAt        DateTime @default(now())
  expiresAt        DateTime

  @@index([expiresAt])
}

model Material {
  id           String    @id @default(cuid())
  type         String
  title        String
  body         Json
  originRefs   String[]  @default([])
  participants String[]  @default([])
  visibility   String
  createdById  String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  createdBy    User      @relation(fields: [createdById], references: [id])

  /// pgvector embedding for semantic search (1536-dim)
  embedding    Unsupported("vector(1536)")?

  @@index([type])
  @@index([visibility])
}

model MemoryEntry {
  id                String    @id @default(cuid())
  type              String
  title             String
  body              String
  status            String
  sourceMaterialId  String?
  signers           Json
  publicReviewUntil DateTime?
  referenceCount    Int       @default(0)
  lastReferencedAt  DateTime?
  supersedes        String?
  supersededBy      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  ownerDepartmentId String?
  ownerUserId       String?
  ownershipLevel    String    @default("company")

  /// pgvector embedding for semantic search (1536-dim)
  embedding         Unsupported("vector(1536)")?

  @@index([type, status])
  @@index([status])
  @@index([ownershipLevel])
  @@index([ownerUserId])
  @@index([ownerDepartmentId])
}

model MemoryPromotionRequest {
  id                String    @id @default(cuid())
  materialId        String
  proposedType      String
  proposedTitle     String
  proposedBody      String
  status            String
  signers           Json
  publicReviewUntil DateTime?
  isEmergencyTrack  Boolean   @default(false)
  createdById       String
  createdAt         DateTime  @default(now())
  finalDecisionAt   DateTime?
  escalationHistory Json?
  level             String    @default("company")
  slaDeadline       DateTime?
  createdBy         User      @relation(fields: [createdById], references: [id])

  @@index([status])
  @@index([createdById])
  @@index([level])
}

model Steward {
  userId       String   @id
  appointedAt  DateTime
  conflictWith String[] @default([])
  createdAt    DateTime @default(now())
}

model Cycle {
  id         String      @id @default(cuid())
  period     String
  name       String
  startDate  DateTime
  endDate    DateTime
  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now())
  objectives Objective[]
  ttis       TTI[]
}

model Objective {
  id                String      @id @default(cuid())
  cycleId           String
  level             String
  parentObjectiveId String?
  ownerId           String
  title             String
  description       String?
  visibility        String      @default("public")
  createdAt         DateTime    @default(now())
  collaboratorIds   String[]    @default([])
  confidence        String      @default("on-track")
  finalScore        Float?
  managerScore      Float?
  retrospective     String?
  reviewedAt        DateTime?
  /// 周期末评分 (Google 0-1.0 风格, null 表示未评)
  selfScore         Float?
  status            String      @default("active")
  tags              String[]    @default([])
  updatedAt         DateTime    @updatedAt
  watcherIds        String[]    @default([])
  weight            Int         @default(100)
  keyResults        KeyResult[]
  cycle             Cycle       @relation(fields: [cycleId], references: [id])
  owner             User        @relation(fields: [ownerId], references: [id])
  parent            Objective?  @relation("ObjParent", fields: [parentObjectiveId], references: [id])
  children          Objective[] @relation("ObjParent")

  @@index([cycleId])
  @@index([ownerId])
  @@index([status])
}

model KeyResult {
  id              String       @id @default(cuid())
  objectiveId     String
  ownerId         String
  coOwnerIds      String[]     @default([])
  title           String
  /// A2.1a: measureType 现支持 binary (做/没做) | numeric | percentage | milestone
  measureType     String       @default("numeric")
  computeMethod   String       @default("latest")
  startValue      Float        @default(0)
  targetValue     Float
  currentValue    Float        @default(0)
  unit            String?
  /// A2.1a: confidence 值域统一为 on-track | at-risk | off-track (旧 green/yellow/red 已淘汰)
  confidence      String       @default("on-track")
  /// 旧 riskStatus (on_track | at_risk | off_track), 保留兼容, 新代码应只用 confidence
  riskStatus      String       @default("on_track")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  collaboratorIds String[]     @default([])
  dueDate         DateTime?
  finalScore      Float?
  selfScore       Float?
  status          String       @default("active")
  tags            String[]     @default([])
  watcherIds      String[]     @default([])
  /// A2.1a 新增:
  weight          Int          @default(100)
  initiatives     Initiative[]
  objective       Objective    @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  owner           User         @relation(fields: [ownerId], references: [id])

  @@index([objectiveId])
  @@index([ownerId])
  @@index([status])
}

model TTI {
  id              String   @id @default(cuid())
  cycleId         String
  ownerId         String
  title           String
  description     String?
  successCriteria String
  startValue      Float?
  targetValue     Float?
  currentValue    Float?
  unit            String?
  completionRate  Float    @default(0)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  cycle           Cycle    @relation(fields: [cycleId], references: [id])
  owner           User     @relation(fields: [ownerId], references: [id])

  @@index([cycleId])
  @@index([ownerId])
}

model Initiative {
  id              String         @id @default(cuid())
  keyResultId     String
  ownerId         String
  title           String
  decisionCardIds String[]       @default([])
  status          String
  dueDate         DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  keyResult       KeyResult      @relation(fields: [keyResultId], references: [id], onDelete: Cascade)
  decisionCards   DecisionCard[] @relation("DecisionInitiatives")

  @@index([keyResultId])
}

/// A2.1a (2026-05-10) — CheckIn 重建为 scope-based 模型.
/// 旧的 weekly + krUpdates/ttiUpdates JSON 周报模型已淘汰 (auto-draft 旧库已废弃).
/// 新模型: 每条 check-in 直接挂在 1 个 Objective 或 1 个 KR 上, 记录进度+信心+三段式叙述.
model CheckIn {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  /// PPP / 三段式叙述
  achievements     String?
  /// 发起 check-in 的人 (User.id)
  authorId         String
  blockers         String?
  confidenceAfter  String
  /// 信心快照, 值域 on-track | at-risk | off-track
  confidenceBefore String
  /// 个人干劲 (happy | neutral | sad), Weekdone 高级版灵感
  mood             String?
  nextSteps        String?
  progressAfter    Float
  /// 进度快照 (0-100), 写入前/后
  progressBefore   Float
  /// 'objective' | 'kr'
  scope            String
  /// 对应 Objective.id 或 KeyResult.id (polymorphic, 不建外键)
  scopeId          String
  author           User     @relation(fields: [authorId], references: [id])

  @@index([scope, scopeId])
  @@index([authorId])
  @@index([createdAt])
}

model ImChannel {
  id                   String         @id @default(cuid())
  /// dm | group | announcement | department | team | project | cross_dept
  type                 String
  name                 String         @default("")
  topic                String?
  visibility           String
  memberIds            String[]       @default([])
  createdById          String
  /// 频道是否由某张决议卡触发 (议事室 → IM 反向链接)
  linkedDecisionCardId String?
  lastMessageAt        DateTime?
  lastMessagePreview   String?
  archivedAt           DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  /// Q2: 系统按组织架构自动建群标记 (人工建群 false)
  autoCreated          Boolean        @default(false)
  /// Q2: 部门/团队群链接 (department / team / cross_dept type 必填)
  /// Department 自含树, team = parentId != null 的 Department
  departmentId         String?
  /// Q2: 项目群可设结束日期 (到期自动 archive)
  projectEndsAt        DateTime?
  memberships          ImMembership[]
  messages             ImMessage[]

  @@index([type])
  @@index([createdById])
  @@index([lastMessageAt])
  @@index([departmentId])
}

model ImMessage {
  id                    String      @id @default(cuid())
  channelId             String
  senderId              String
  /// 'user' | 'system' | 'persona'
  senderKind            String      @default("user")
  body                  String
  /// ImMention[] (kind: 'user'|'persona'|'channel'|'memory', userId 或 ref)
  mentions              Json        @default("[]")
  /// ImAttachment[] (file/image/decisionCard/memory)
  attachments           Json?
  parentMessageId       String?
  /// IM → 议事室反向链接
  spawnedDecisionCardId String?
  editedAt              DateTime?
  deletedAt             DateTime?
  createdAt             DateTime    @default(now())
  spawnedPromotionId    String?
  channel               ImChannel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  parentMessage         ImMessage?  @relation("ImThread", fields: [parentMessageId], references: [id])
  threadReplies         ImMessage[] @relation("ImThread")

  @@index([channelId, createdAt])
  @@index([senderId])
  @@index([parentMessageId])
}

model ImMembership {
  /// 复合键: `${channelId}:${userId}`
  id          String    @id
  channelId   String
  userId      String
  /// 'owner' | 'admin' | 'member'
  role        String    @default("member")
  joinedAt    DateTime  @default(now())
  lastReadAt  DateTime?
  unreadCount Int       @default(0)
  muted       Boolean   @default(false)
  /// 关注此频道的 Persona 触发关键字 (可选)
  notifyOn    String[]  @default([])
  channel     ImChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([userId])
  @@index([channelId])
}

model NineBoxSnapshot {
  id         String   @id @default(cuid())
  userId     String
  cycleId    String
  kpiScore   Float
  ttiScore   Float
  cell       String
  capturedAt DateTime @default(now())

  @@index([userId, cycleId])
}

model OneOnOneMeeting {
  id                 String               @id @default(cuid())
  tenantId           String               @default("default")
  managerId          String
  reportId           String
  cadence            String               @default("biweekly")
  scheduledAt        DateTime
  startedAt          DateTime?
  completedAt        DateTime?
  status             String               @default("scheduled")
  agendaManager      String?
  agendaReport       String?
  noteProgress       String?
  noteBlockers       String?
  noteNextSteps      String?
  linkedKrIds        String[]             @default([])
  moodScore          Int?
  /// 主管私密备注: API 层按 requester strip (员工读不到)
  privateManagerNote String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  actionItems        OneOnOneActionItem[]

  @@index([tenantId])
  @@index([managerId])
  @@index([reportId])
  @@index([scheduledAt])
}

model OneOnOneActionItem {
  id                 String          @id @default(cuid())
  meetingId          String
  text               String
  assigneeId         String
  dueDate            DateTime?
  done               Boolean         @default(false)
  /// A3.1 cross-link: 提升为 KR Initiative 后的引用 (软绑定)
  linkedInitiativeId String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  meeting            OneOnOneMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@index([assigneeId])
  @@index([linkedInitiativeId])
}

model Review360Cycle {
  id             String                @id @default(cuid())
  tenantId       String                @default("default")
  name           String
  startDate      DateTime
  endDate        DateTime
  status         String                @default("draft")
  /// Review360Question[] JSON: { id, dimension, prompt, rated, qualitative }
  questions      Json
  anonymizePeers Boolean               @default(true)
  createdBy      String
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  assignments    Review360Assignment[]
  submissions    Review360Submission[]

  @@index([tenantId])
  @@index([status])
  @@index([createdBy])
}

model Review360Submission {
  id           String         @id @default(cuid())
  cycleId      String
  subjectId    String
  /// 评估人 User.id — 故意不建索引 (D6 隐私决策)
  raterId      String
  raterType    String
  /// answers: { questionId, score?, text? }[]
  answers      Json
  strengths    String
  improvements String
  overallScore Float?
  submittedAt  DateTime       @default(now())
  cycle        Review360Cycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@index([cycleId])
  @@index([subjectId])
}

model Review360Assignment {
  id          String         @id @default(cuid())
  cycleId     String
  subjectId   String
  raterId     String
  raterType   String
  submitted   Boolean        @default(false)
  submittedAt DateTime?
  createdAt   DateTime       @default(now())
  cycle       Review360Cycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@unique([cycleId, subjectId, raterId])
  @@index([cycleId])
  @@index([raterId, submitted])
}

model MemoryDowngradeRequest {
  id         String   @id
  memoryId   String
  proposedBy String
  reason     String
  metrics    Json
  status     String
  decision   Json?
  createdAt  DateTime @default(now())

  @@index([memoryId])
  @@index([proposedBy])
  @@index([status])
}


// =============================================================================
// A2.2 SaaS Multi-tenant (Workspace + Billing)
// Added 2026-05-12 · Phase 4.1
// =============================================================================

model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logoUrl     String?
  description String?

  // Billing
  planId      String?
  subscriptionStatus String @default("active") // active | past_due | cancelled | suspended

  // Settings
  settings    Json     @default("{}")

  // Limits (enforced at app layer)
  maxUsers    Int      @default(10)
  maxStorageMb Int     @default(1024)
  maxChannels  Int?     @default(10)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  users       User[]
  plan        Plan?    @relation(fields: [planId], references: [id])
  subscriptions Subscription[]

  @@index([slug])
  @@index([subscriptionStatus])
}

model Plan {
  id          String   @id @default(cuid())
  name        String   @unique // free | pro | enterprise
  displayName String
  description String?

  // Pricing (monthly, in cents)
  priceMonthCents  Int @default(0)
  priceYearCents   Int @default(0)

  // Limits
  maxUsers         Int @default(10)
  maxStorageMb     Int @default(1024)
  maxChannels      Int @default(10)
  apiRateLimitRpm  Int @default(60)

  // Feature flags
  features         Json @default("{}")

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workspaces       Workspace[]
  subscriptions    Subscription[]
}

model Subscription {
  id            String   @id @default(cuid())
  workspaceId   String
  planId        String

  // Stripe / payment provider refs (optional)
  provider      String   @default("stripe")
  providerSubId String?

  status        String   @default("trialing") // trialing | active | past_due | cancelled | expired
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  plan          Plan      @relation(fields: [planId], references: [id])

  @@index([workspaceId])
  @@index([status])
}

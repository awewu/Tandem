// Tandem (牛马搭子) · Database Schema
//
// 此 schema 与 lib/types/* 一一对应.
// 团队后续需:
//   1. npm i -D prisma && npm i @prisma/client
//   2. npx prisma init (生成 .env DATABASE_URL)
//   3. npx prisma migrate dev --name init
//   4. 替换 lib/storage/memory-store.ts 为 Prisma client
//
// 设计原则:
//   - 任何业务表都有 createdAt / updatedAt
//   - 软删除使用 deletedAt (V2 起加)
//   - 全局使用 cuid() (排序友好且分布式安全)
//   - 中文字段统一在代码层处理, DB 字段全英文
//   - 多租户: 所有业务表必含 tenantId (V2 SaaS 启用)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// 用户 / 组织
// =============================================================================

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  emailVerifiedAt DateTime?
  name        String
  avatarUrl   String?
  departmentId String?
  managerId   String?
  // 多租户 (V2 SaaS 启用)
  tenantId    String   @default("default")
  // 角色 (RBAC)
  roles       String[] @default([])
  // 关联企微/钉钉/飞书 unionId 用于 SSO (可选, 自研账号为主)
  ssoBindings Json?
  // 自研账号: 是否禁用
  disabled    Boolean  @default(false)
  // 自研账号: 失败登录次数 (防爆破)
  failedLoginCount Int  @default(0)
  lockedUntil DateTime?
  lastLoginAt DateTime?
  lastLoginIp String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  department  Department? @relation(fields: [departmentId], references: [id])
  manager     User?       @relation("ReportTo", fields: [managerId], references: [id])
  reports     User[]      @relation("ReportTo")

  // 自研身份系统
  passwordHash   PasswordHash?
  sessions       Session[]
  mfaSecret      MfaSecret?
  invitesSent    Invite[]   @relation("InviteSender")

  // 反向引用
  personas       Persona[]
  decisionCards  DecisionCard[]
  objectives     Objective[]
  keyResults     KeyResult[]
  ttis           TTI[]
  checkIns       CheckIn[]
  materials      Material[]
  promotionsOpened MemoryPromotionRequest[]

  @@index([tenantId])
  @@index([email])
}

// =============================================================================
// 自研身份系统 (Native Auth - V1 主路径)
// =============================================================================

model PasswordHash {
  userId       String   @id
  /// argon2id / bcrypt hash
  hash         String
  algorithm    String   @default("argon2id")
  /// 强制下次登录改密 (admin 重置后)
  mustChange   Boolean  @default(false)
  changedAt    DateTime @default(now())
  /// 密码历史 hash (防止复用最近 N 次)
  historyHashes String[] @default([])

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  /// 设备指纹 (UA + IP hash)
  deviceFingerprint String?
  userAgent    String?
  ip           String?
  /// 会话刷新令牌哈希 (refresh token, 永不明文存)
  refreshTokenHash String  @unique
  /// 是否提升到 MFA 已验证状态
  mfaVerified  Boolean  @default(false)
  expiresAt    DateTime
  revokedAt    DateTime?
  revokeReason String?
  createdAt    DateTime @default(now())
  lastSeenAt   DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model MfaSecret {
  userId       String   @id
  /// TOTP secret (encrypted at rest, 仅 server 可解)
  encryptedSecret String
  /// 10 个一次性恢复码 (hash)
  recoveryCodeHashes String[] @default([])
  enrolledAt   DateTime @default(now())
  lastUsedAt   DateTime?

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Invite {
  id           String   @id @default(cuid())
  /// 邀请码 hash (明文不入库)
  codeHash     String   @unique
  /// 锁定到特定邮箱 (可选; 不锁则任何邮箱可领)
  email        String?
  /// 预设角色 / 部门
  presetRoles  String[] @default([])
  presetDepartmentId String?
  tenantId     String   @default("default")
  /// 谁发的
  invitedById  String
  /// 备注 (本次邀请用途)
  note         String?
  /// 单次 / 多次使用
  maxUses      Int      @default(1)
  usedCount    Int      @default(0)
  expiresAt    DateTime
  redeemedAt   DateTime?
  createdAt    DateTime @default(now())

  invitedBy    User     @relation("InviteSender", fields: [invitedById], references: [id])

  @@index([email])
  @@index([expiresAt])
  @@index([invitedById])
}

model AuthEvent {
  id        String   @id @default(cuid())
  userId    String?
  email     String?
  /// 事件类型: register | login | login_failed | logout | mfa_verified | mfa_failed | password_changed | invite_redeemed | session_revoked
  eventType String
  ip        String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([email])
  @@index([eventType])
  @@index([createdAt])
}

model Department {
  id        String   @id @default(cuid())
  name      String
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent   Department?  @relation("DeptParent", fields: [parentId], references: [id])
  children Department[] @relation("DeptParent")
  users    User[]
}

// =============================================================================
// Decision Card (决议卡 - 工作原子单元)
// =============================================================================

model DecisionCard {
  id              String   @id @default(cuid())
  schemaVersion   String   @default("tandem.v1")
  title           String
  decisionClass   String   // 'simple' | 'complex' | 'strategic'
  convergenceState String  // DIVERGE | CONVERGE | COMMIT | ESCALATED | VETOED
  elapsedSeconds  Int      @default(0)
  hardDeadlineAt  DateTime?

  // KR 软绑定 (Q2): 默认必选, 可选 escape hatch (no KR + reason)
  // 不变量 (app 层守门): primaryKrId XOR noKrReason 必须非空
  primaryKrId     String?
  noKrReason      String?  // 长度 ≥ 10 字符 (反"占位理由")

  // 关联 (次要 KR + TTI 多对多, 仍保留)
  relatedKr       String[] @default([])
  relatedTti      String[] @default([])
  origins         Json?    // {meetingRecording, chatThread, fileRefs}
  materialRefs    String[] @default([])

  // 选项 + 选择
  options         Json     // DecisionOption[]
  selected        String?  // 'A' | 'B' | 'C' | 'D'
  selectedById    String?
  selectedAt      DateTime?

  // 影响 KR 预期
  expectedKrImpact Json?   // {kr, deltaPp}[]

  // 复盘
  retrospective   Json?

  // 24h 否决窗口
  vetoWindowEnds  DateTime?

  // 水印 (反 AI 欺诈)
  watermark       Json     // {isProxy, proxyType, ...}

  createdById     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  createdBy       User     @relation(fields: [createdById], references: [id])
  actionItems     ActionItem[]
  initiatives     Initiative[] @relation("DecisionInitiatives")

  @@index([convergenceState])
  @@index([createdById])
  @@index([createdAt])
}

model ActionItem {
  id              String   @id @default(cuid())
  decisionCardId  String
  ownerId         String
  task            String
  due             DateTime
  status          String   // open | in_progress | done | blocked
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  decisionCard    DecisionCard @relation(fields: [decisionCardId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([status])
}

// =============================================================================
// Persona (拿捏老板)
// =============================================================================

model Persona {
  id                 String   @id @default(cuid())
  userId             String   @unique
  schemaVersion      String   @default("tandem.v1")
  stage              String   // newborn | apprentice | assistant | deputy | partner
  stageEnteredAt     DateTime
  delegationLevel    String
  decisionHistory    Json     // DecisionHistoryStats
  styleProfile       Json     // StyleProfile
  growthAreas        Json     // GrowthArea[]
  bossCaptureScore   Float    @default(0)
  dataOwnership      Json
  learningActive     Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// =============================================================================
// Knowledge Layers (Origins / Materials / Memory / Baseline)
// =============================================================================

model Origin {
  id                String   @id @default(cuid())
  type              String   // meeting_recording | chat_thread | ...
  sourceUrl         String?
  participants      String[] @default([])
  encryptedBlobRef  String?
  retentionDays     Int      @default(90)
  createdAt         DateTime @default(now())
  expiresAt         DateTime

  @@index([expiresAt])
}

model Material {
  id            String   @id @default(cuid())
  type          String
  title         String
  body          Json
  originRefs    String[] @default([])
  participants  String[] @default([])
  visibility    String   // public | team | private
  // embedding (vector(1536)) — V2 retriever 启用. 需先装 pgvector 扩展:
  //   CREATE EXTENSION IF NOT EXISTS vector;
  // 然后取消下面注释 + npm run db:migrate
  // embedding     Unsupported("vector(1536)")?
  createdById   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  createdBy     User     @relation(fields: [createdById], references: [id])

  @@index([type])
  @@index([visibility])
}

model MemoryEntry {
  id                String   @id @default(cuid())
  type              String   // sop | case | redline | value | lesson
  title             String
  body              String
  status            String   // active | revising | inactive | deprecated
  sourceMaterialId  String?
  signers           Json     // MemorySigner[]
  publicReviewUntil DateTime?
  // embedding         Unsupported("vector(1536)")?  // V2 retriever, 同 Material
  referenceCount    Int      @default(0)
  lastReferencedAt  DateTime?
  supersedes        String?
  supersededBy      String?

  // Ownership 4 级 (Q1, 2026-05-10):
  //   company    → 全员可见, Lv3 签批
  //   department → 部门内可见, Lv2 签批
  //   team       → 团队内可见, Lv1 签批
  //   personal   → 自己 + 主管可见, 无需签批 (个人笔记)
  // 取代旧的 visibility 字段语义.
  ownershipLevel    String   @default("company")
  ownerUserId       String?  // personal 时
  ownerDepartmentId String?  // department / team 时

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([type, status])
  @@index([status])
  @@index([ownershipLevel])
  @@index([ownerUserId])
  @@index([ownerDepartmentId])
}

model MemoryPromotionRequest {
  id                  String   @id @default(cuid())
  materialId          String
  proposedType        String
  proposedTitle       String
  proposedBody        String
  status              String   // pending | approved | rejected | expired
  signers             Json     // {businessLeader, steward, ceo}
  publicReviewUntil   DateTime?
  isEmergencyTrack    Boolean  @default(false)
  createdById         String
  createdAt           DateTime @default(now())
  finalDecisionAt     DateTime?

  createdBy           User     @relation(fields: [createdById], references: [id])

  @@index([status])
  @@index([createdById])
}

model Steward {
  userId        String   @id
  appointedAt   DateTime
  conflictWith  String[] @default([])
  createdAt     DateTime @default(now())
}

// =============================================================================
// OKR / TTI (双轨)
// =============================================================================

model Cycle {
  id        String   @id @default(cuid())
  period    String   // year | half | quarter | bi_monthly | month | custom
  name      String
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  objectives Objective[]
  ttis       TTI[]
}

model Objective {
  id                String   @id @default(cuid())
  cycleId           String
  level             String   // company | team | individual
  parentObjectiveId String?
  ownerId           String
  title             String
  description       String?
  visibility        String   @default("public")
  // A2.1a (2026-05-10) — Prisma 与 zustand 语义对齐:
  // weight: 0-100, 在父 Objective 下的权重
  // status: active | paused | completed | abandoned
  // confidence: on-track | at-risk | off-track (替代 KR 的 green/yellow/red 旧值)
  weight            Int      @default(100)
  status            String   @default("active")
  confidence        String   @default("on-track")
  tags              String[] @default([])
  collaboratorIds   String[] @default([])
  watcherIds        String[] @default([])
  /// 周期末评分 (Google 0-1.0 风格, null 表示未评)
  selfScore         Float?
  managerScore      Float?
  finalScore        Float?
  retrospective     String?
  reviewedAt        DateTime?
  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())

  cycle             Cycle    @relation(fields: [cycleId], references: [id])
  parent            Objective? @relation("ObjParent", fields: [parentObjectiveId], references: [id])
  children          Objective[] @relation("ObjParent")
  owner             User     @relation(fields: [ownerId], references: [id])
  keyResults        KeyResult[]

  @@index([cycleId])
  @@index([ownerId])
  @@index([status])
}

model KeyResult {
  id            String   @id @default(cuid())
  objectiveId   String
  ownerId       String
  coOwnerIds    String[] @default([])
  title         String
  /// A2.1a: measureType 现支持 binary (做/没做) | numeric | percentage | milestone
  measureType   String   @default("numeric")
  computeMethod String   @default("latest") // cumulative | latest | average
  startValue    Float    @default(0)
  targetValue   Float
  currentValue  Float    @default(0)
  unit          String?
  /// A2.1a: confidence 值域统一为 on-track | at-risk | off-track (旧 green/yellow/red 已淘汰)
  confidence    String   @default("on-track")
  /// 旧 riskStatus (on_track | at_risk | off_track), 保留兼容, 新代码应只用 confidence
  riskStatus    String   @default("on_track")
  /// A2.1a 新增:
  weight        Int      @default(100)
  status        String   @default("active") // active | completed | abandoned
  dueDate       DateTime?
  tags          String[] @default([])
  collaboratorIds String[] @default([])
  watcherIds    String[] @default([])
  selfScore     Float?
  finalScore    Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  objective     Objective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  owner         User      @relation(fields: [ownerId], references: [id])
  initiatives   Initiative[]

  @@index([objectiveId])
  @@index([ownerId])
  @@index([status])
}

model TTI {
  id                  String   @id @default(cuid())
  cycleId             String
  ownerId             String
  title               String
  description         String?
  successCriteria     String
  startValue          Float?
  targetValue         Float?
  currentValue        Float?
  unit                String?
  completionRate      Float    @default(0)
  // yearEndBonusModifier removed 2026-05-10 (Constitution §4: TTI must
  // never affect compensation. Type layer enforces affectsCompensation:
  // readonly false; this DB column was the last residual. See migration
  // 20260510_drop_tti_bonus_modifier.)
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  cycle               Cycle    @relation(fields: [cycleId], references: [id])
  owner               User     @relation(fields: [ownerId], references: [id])

  @@index([cycleId])
  @@index([ownerId])
}

model Initiative {
  id              String   @id @default(cuid())
  keyResultId     String
  ownerId         String
  title           String
  decisionCardIds String[] @default([])
  status          String   // planned | in_progress | done | blocked
  dueDate         DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  keyResult       KeyResult     @relation(fields: [keyResultId], references: [id], onDelete: Cascade)
  decisionCards   DecisionCard[] @relation("DecisionInitiatives")

  @@index([keyResultId])
}

/// A2.1a (2026-05-10) — CheckIn 重建为 scope-based 模型.
/// 旧的 weekly + krUpdates/ttiUpdates JSON 周报模型已淘汰 (auto-draft 旧库已废弃).
/// 新模型: 每条 check-in 直接挂在 1 个 Objective 或 1 个 KR 上, 记录进度+信心+三段式叙述.
model CheckIn {
  id                String   @id @default(cuid())
  /// 'objective' | 'kr'
  scope             String
  /// 对应 Objective.id 或 KeyResult.id (polymorphic, 不建外键)
  scopeId           String
  /// 发起 check-in 的人 (User.id)
  authorId          String
  /// 进度快照 (0-100), 写入前/后
  progressBefore    Float
  progressAfter     Float
  /// 信心快照, 值域 on-track | at-risk | off-track
  confidenceBefore  String
  confidenceAfter   String
  /// PPP / 三段式叙述
  achievements      String?
  blockers          String?
  nextSteps         String?
  /// 个人干劲 (happy | neutral | sad), Weekdone 高级版灵感
  mood              String?
  createdAt         DateTime @default(now())

  author            User     @relation(fields: [authorId], references: [id])

  @@index([scope, scopeId])
  @@index([authorId])
  @@index([createdAt])
}

// =============================================================================
// IM (消息 / 群聊 - 自建 IM, 复用 Hermes runtime + PG)
//
// 设计参考 Rocket.Chat / Mattermost 的 channel + membership + message 三表结构.
// 不引 Mongo, 走 PG. 见 docs/MANIFESTO.md §18.
// =============================================================================

model ImChannel {
  id                   String   @id @default(cuid())
  /// dm | group | announcement | department | team | project | cross_dept
  type                 String
  name                 String   @default("")
  topic                String?
  visibility           String   // 'public' | 'private'
  memberIds            String[] @default([])
  createdById          String

  /// Q2: 部门/团队群链接 (department / team / cross_dept type 必填)
  /// Department 自含树, team = parentId != null 的 Department
  departmentId         String?
  /// Q2: 系统按组织架构自动建群标记 (人工建群 false)
  autoCreated          Boolean  @default(false)
  /// Q2: 项目群可设结束日期 (到期自动 archive)
  projectEndsAt        DateTime?

  /// 频道是否由某张决议卡触发 (议事室 → IM 反向链接)
  linkedDecisionCardId String?
  lastMessageAt        DateTime?
  lastMessagePreview   String?
  archivedAt           DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  messages             ImMessage[]
  memberships          ImMembership[]

  @@index([type])
  @@index([createdById])
  @@index([lastMessageAt])
  @@index([departmentId])
}

model ImMessage {
  id                       String   @id @default(cuid())
  channelId                String
  senderId                 String
  /// 'user' | 'system' | 'persona'
  senderKind               String   @default("user")
  body                     String
  /// ImMention[] (kind: 'user'|'persona'|'channel'|'memory', userId 或 ref)
  mentions                 Json     @default("[]")
  /// ImAttachment[] (file/image/decisionCard/memory)
  attachments              Json?
  parentMessageId          String?
  /// IM → 议事室反向链接
  spawnedDecisionCardId    String?
  editedAt                 DateTime?
  deletedAt                DateTime?
  createdAt                DateTime @default(now())

  channel                  ImChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  parentMessage            ImMessage? @relation("ImThread", fields: [parentMessageId], references: [id])
  threadReplies            ImMessage[] @relation("ImThread")

  @@index([channelId, createdAt])
  @@index([senderId])
  @@index([parentMessageId])
}

model ImMembership {
  /// 复合键: `${channelId}:${userId}`
  id           String   @id
  channelId    String
  userId       String
  /// 'owner' | 'admin' | 'member'
  role         String   @default("member")
  joinedAt     DateTime @default(now())
  lastReadAt   DateTime?
  unreadCount  Int      @default(0)
  muted        Boolean  @default(false)
  /// 关注此频道的 Persona 触发关键字 (可选)
  notifyOn     String[] @default([])

  channel      ImChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([userId])
  @@index([channelId])
}

// =============================================================================
// 9 宫格历史快照 (季度归档用)
// =============================================================================

model NineBoxSnapshot {
  id          String   @id @default(cuid())
  userId      String
  cycleId     String
  kpiScore    Float
  ttiScore    Float
  cell        String   // star | rising_talent | ...
  capturedAt  DateTime @default(now())

  @@index([userId, cycleId])
}

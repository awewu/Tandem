# Tandem · 环境变量模板
# 复制为 .env (dev) 或 .env.production (prod)，按用途填值

# ============================================================
# 核心
# ============================================================
NODE_ENV=development                          # development | production | test
LOG_LEVEL=info                                # debug | info | warn | error
APP_PORT=3000                                 # 容器对外端口

# ============================================================
# PostgreSQL (Drizzle ORM)
# ============================================================
DATABASE_URL=postgresql://tandem:tandem@localhost:5440/tandem
SHADOW_DATABASE_URL=postgresql://tandem:tandem@localhost:5440/tandem_shadow

# 仅 prod 用 (docker-compose.prod.yml 注入)
POSTGRES_USER=tandem
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=tandem

# ============================================================
# Redis (session / rate-limit / cache)
# ============================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ============================================================
# MinIO / S3 兼容对象存储 (Drive 文件)
# ============================================================
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=tandem
S3_SECRET_KEY=CHANGE_ME_STRONG_PASSWORD
S3_BUCKET_DRIVE=tandem-drive
S3_BUCKET_ATTACHMENTS=tandem-attachments
S3_FORCE_PATH_STYLE=true

MINIO_ROOT_USER=tandem
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ============================================================
# Auth / Session
# ============================================================
NEXTAUTH_SECRET=CHANGE_ME_LONG_RANDOM_HEX_64_CHARS
NEXTAUTH_URL=http://localhost:3000
SESSION_TTL_SEC=604800                        # 7 天
ACCESS_TOKEN_TTL_SEC=900                      # 15 分钟
ALLOW_DEMO_AUTH=0                             # 1 = 允许 demo 用户跳过登录 (仅 dev)

# PLM / 创新匠台 SSO
# Tandem 点击 PLM 时会签发短期 JWT 并跳转到 PLM 的 /api/auth/sso/callback。
# 生产必须和 PLM 环境变量 TANDEM_SSO_JWT_SECRET 使用同一个强随机密钥。
PLM_STUDIO_URL=https://studio.rhautt.com
PLM_SSO_JWT_SECRET=CHANGE_ME_SHARED_RANDOM_SECRET_WITH_PLM

# Bcrypt cost (生产 ≥ 12)
BCRYPT_ROUNDS=12

# ============================================================
# 手机号 + 短信验证码 登录 (可选; 缺省=未配置, 登录页提示"待配置")
# ============================================================
# SMS_PROVIDER: none(默认) | log(dev: 验证码打到服务端日志, 不发真实短信) | aliyun | tencent
SMS_PROVIDER=none
# 接阿里云短信 (SMS_PROVIDER=aliyun 时, 在 lib/auth/sms-provider.ts 实现并填):
# SMS_ALIYUN_ACCESS_KEY_ID=
# SMS_ALIYUN_ACCESS_KEY_SECRET=
# SMS_ALIYUN_SIGN_NAME=
# SMS_ALIYUN_TEMPLATE_CODE=

# ============================================================
# 微信扫码登录 (可选; 缺 APP_ID/SECRET = 未配置, 登录页提示"待配置")
# 微信开放平台网站应用: https://open.weixin.qq.com
# ============================================================
# WECHAT_APP_ID=
# WECHAT_APP_SECRET=
# WECHAT_REDIRECT_URI=http://localhost:3000/api/auth/wechat/callback

# MFA
MFA_REQUIRED_FOR_ROLES=admin,steward          # 这些角色强制 MFA

# ============================================================
# 公司域名白名单 — 员工自助注册 (无需邀请码)
# 多个域名用逗号分隔, 如: company.com,corp.example.com
# 留空 → 关闭自助注册路径 (员工只能通过邀请码进入)
# 配置示例: INTERNAL_EMAIL_DOMAINS=your-company.com
# ============================================================
INTERNAL_EMAIL_DOMAINS=

# ============================================================
# Owner bootstrap (首次启动自动创建公司主)
# 三个变量必须同时配置, 否则跳过. 部署后立即改密 + 启 MFA.
# ============================================================
TANDEM_BOOTSTRAP_OWNER_EMAIL=
TANDEM_BOOTSTRAP_OWNER_PASSWORD=
TANDEM_BOOTSTRAP_OWNER_NAME=Owner

# ============================================================
# Rate limiting
# ============================================================
RATE_LIMIT_LOGIN_PER_HOUR=5                   # /api/auth/login per IP per hour
RATE_LIMIT_API_PER_MINUTE=120                 # /api/* per user per minute

# ============================================================
# LLM Providers (按需启用)
# ============================================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# ============================================================
# Embedding 向量化 (语义召回的氧气)
# ------------------------------------------------------------
# 缺省 EMBEDDING_PROVIDER=none → baseline-guard / OKR drift / memory rerank 全部
# 降级到 Jaccard 字面匹配 (懂"客户数据严禁出境", 但"把信息传到境外服务器"这种同义改写
# 会漏)。配上任一 provider, 全链路判别力一次性升到语义级。lib/infra/embedding.ts 已就绪,
# 这是纯 ops 开关, 不需改代码。
#
# 选项 A · 本地 Ollama (免费, 民企无 API 预算首选; 需先 `ollama pull bge-m3`):
#   EMBEDDING_PROVIDER=ollama
#   EMBEDDING_MODEL=bge-m3
#   EMBEDDING_API_URL=http://localhost:11434/api/embeddings
#
# 选项 B · OpenAI 兼容云 (DeepSeek/OpenAI/通义等):
#   EMBEDDING_PROVIDER=openai
#   EMBEDDING_MODEL=text-embedding-3-small
#   EMBEDDING_API_URL=https://api.openai.com/v1/embeddings
#   EMBEDDING_API_KEY=sk-...
#
# 配好后跑一次回填, 给历史 Memory 落库向量 (避免运行时 N+1 重算):
#   node scripts/backfill-embeddings.mjs
# ============================================================
EMBEDDING_PROVIDER=none
EMBEDDING_MODEL=
EMBEDDING_API_URL=
EMBEDDING_API_KEY=

# ============================================================
# 监控/观测 (可选)
# ============================================================
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
